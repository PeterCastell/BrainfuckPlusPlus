&&glfwWindowHint        ($call_function({7$0})(+14))
&&glfwGetWindowSize     ($call_function({8$0})(+16))
&&glfwGetKey            ($call_function({9$0})(+20))

&&k32CreateFileA        ($call_function({32$0})(+9))
&&k32ReadFile           ($call_function({33$0})(+10))
&&k32CloseHandle        ($call_function({34$0})(+3))

&&glClearColor          ($call_function({10$0})(+6))
&&glClear               ($call_function({11$0})(+7))
&&glCreateShader        ($call_function({12$0})(+11))
&&glShaderSource        ($call_function({13$0})(+12))
&&glCompileShader       ($call_function({14$0})(+7))
&&glGetShader           ($call_function({15$0})(+13))
&&glGetShaderInfoLog    ($call_function({16$0})(+12))
&&glCreateProgram       ($call_function({17$0})(+1))
&&glAttachShader        ($call_function({18$0})(+14))
&&glGetError            ($call_function({19$0})(+1))
&&glLinkProgram         ($call_function({20$0})(+7))
&&glDeleteShader        ($call_function({21$0})(+7))
&&glUseProgram          ($call_function({22$0})(+7))
&&glGetUniformLocation  ($call_function({23$0})(+15))
&&glUniform1i           ($call_function({24$0})(+14))
&&glUniform2i           ($call_function({25$0})(+17))
&&glDrawArrays          ($call_function({26$0})(+17))
&&glCreateVertexArrays  ($call_function({27$0})(+18))
&&glBindVertexArray     ($call_function({28$0})(+7))
&&glViewport            ($call_function({29$0})(+19))